        "intro": {
          "title": "1. Einführung",
          "body": "Jibiaar ist eine persönliche Finanzverwaltungs-App, die Nutzern hilft, ihr monatliches Budget, Ausgaben und finanzielle Ziele zu verfolgen. Außerdem bietet sie einen persischsprachigen KI-Assistenten für Finanzberatung. Durch die Nutzung des Dienstes akzeptieren Sie die folgenden Bedingungen."
        },
        "useTitle": "2. Nutzungsbedingungen",
        "age": {
          "title": "2.1 Alter",
          "body": "Die Nutzung von Jibiaar ist für Personen über 18 Jahren gestattet. Mit der Registrierung bestätigen Sie, mindestens 18 Jahre alt zu sein. Wenn ein Elternteil oder Vormund für einen Minderjährigen registriert, liegt die Verantwortung beim Erziehungsberechtigten."
        },
        "allowed": {
          "title": "2.2 Erlaubte Nutzung",
          "body": "Sie verpflichten sich, diesen Dienst nur für rechtmäßige und persönliche Zwecke zu nutzen. Kommerzielle Nutzung, Weitergabe von Daten an Dritte, unautorisiertes Kopieren oder Versuche unbefugten Zugriffs sind verboten."
        },
        "privacyTitle": "3. Datenschutz",
        "collect": {
          "title": "3.1 Erhobene Daten",
          "intro": "Jibiaar hat <strong>keine Verbindung zu Ihren Bankkonten</strong>. Alle Finanzdaten (Transaktionen, Budgets, Ziele) werden manuell von Ihnen eingegeben. Wir erfassen folgende Informationen:",
          "items": [
            "Telefonnummer zur Authentifizierung",
            "Profilinformationen (Name, Wohnort, Einkommensbereich), die Sie selbst eingeben",
            "Transaktionen und Budgets, die Sie erfassen",
            "Nachrichten mit dem KI-Assistenten"
          ]
        },
        "use": {
          "title": "3.2 Nutzung der Daten",
          "body": "Ihre Daten werden zur Verbesserung des Dienstes, Personalisierung der Beratung und Optimierung der Nutzererfahrung verwendet. Ihre Informationen werden nicht verkauft oder an Dritte weitergegeben, außer wenn gesetzlich vorgeschrieben."
        },
        "security": {
          "title": "3.3 Datensicherheit",
          "body": "Wir verwenden Industriestandards zur Datenverschlüsselung. Dennoch ist kein System zu 100% sicher, und wir können absolute Sicherheit nicht garantieren."
        },
        "aiTitle": "4. KI-Assistent",
        "aiAdvice": {
          "title": "4.1 Art der Beratung",
          "body": "Der KI-Assistent von Jibiaar liefert allgemeine Informationen und Bildungsvorschläge. Diese sind <strong>keine professionelle Finanzberatung</strong> und ersetzen keinen zugelassenen Finanzberater. Konsultieren Sie für wichtige Entscheidungen einen qualifizierten Experten."
        },
        "aiLimit": {
          "title": "4.2 Haftungsbeschränkung",
          "body": "Jibiaar übernimmt keine Haftung für finanzielle Verluste, die aus Entscheidungen aufgrund von Vorschlägen des KI-Assistenten entstehen."
        },
        "subscription": {
          "title": "5. Abonnementdienste",
          "body": "Einige erweiterte Funktionen erfordern ein Abonnement oder Tokens. Preise werden vor dem Kauf klar angezeigt. Alle Käufe sind endgültig; Rückerstattungen sind nur in besonderen Fällen nach Prüfung durch den Support möglich."
        },
        "changes": {
          "title": "6. Änderungen der Bedingungen",
          "body": "Wir behalten uns das Recht vor, diese Bedingungen jederzeit zu aktualisieren. Wichtige Änderungen werden über In-App-Benachrichtigungen mitgeteilt. Weitere Nutzung nach Bekanntgabe gilt als Zustimmung."
        },
        "contact": {
          "title": "7. Kontakt",
          "body": "Bei Fragen oder Bedenken erreichen Sie uns per E-Mail unter {email} oder über den In-App-Support. Unser Team ist bereit zu antworten."
        }
      }
