          "title": "1. Service Introduction",
          "body": "Jibiaar is a personal financial management application that helps users track and manage their monthly budgets, expenses, and financial goals. It also offers a Persian-language AI assistant for financial advice. By using this service, you accept the following terms and conditions."
        },
        "useTitle": "2. Terms of Use",
        "age": {
          "title": "2.1 Age",
          "body": "Use of Jibiaar is permitted for those over 18. By registering, you confirm you are at least 18 years old. If a parent or guardian registers for a user under 18, the responsibility lies with the legal guardian."
        },
        "allowed": {
          "title": "2.2 Allowed Use",
          "body": "You commit to use this service only for lawful and personal purposes. Commercial use, transfer of data to third parties, unauthorized copying of content, or any attempt to gain unauthorized access to our systems is prohibited."
        },
        "privacyTitle": "3. Privacy and Data",
        "collect": {
          "title": "3.1 Data We Collect",
          "intro": "Jibiaar has <strong>no connection to your bank accounts</strong>. All financial data (transactions, budgets, goals) is entered manually by you. We collect the following information:",
          "items": [
            "Phone number for authentication",
            "Profile info (name, location, income range) you enter yourself",
            "Transactions and budgets you record",
            "Conversation messages with the AI assistant"
          ]
        },
        "use": {
          "title": "3.2 How We Use Data",
          "body": "Your data is used to provide better service, personalize financial advice, and improve user experience. Your information is not sold or shared with any third party except where legally required."
        },
        "security": {
          "title": "3.3 Data Security",
          "body": "We use industry-standard encryption to protect your data. However, no system is 100% secure and we cannot guarantee absolute security."
        },
        "aiTitle": "4. AI Assistant",
        "aiAdvice": {
          "title": "4.1 Nature of Advice",
          "body": "The Jibiaar AI assistant provides general information and educational suggestions. These suggestions are <strong>not professional financial advice</strong> and do not replace a licensed financial advisor. For important financial decisions, always consult a qualified expert."
        },
        "aiLimit": {
          "title": "4.2 Limitation of Liability",
          "body": "Jibiaar accepts no liability for any financial losses resulting from decisions made based on the AI assistant's suggestions."
        },
        "subscription": {
          "title": "5. Subscription Services",
          "body": "Some advanced AI assistant features require purchasing a subscription or tokens. Prices are clearly shown before purchase. All purchases are final, and refunds are only possible in special cases after review by the support team."
        },
        "changes": {
          "title": "6. Changes to Terms",
          "body": "We reserve the right to update these terms at any time. Important changes will be communicated via in-app notifications. Continued use of the service after changes are announced means acceptance of the new terms."
        },
        "contact": {
          "title": "7. Contact Us",
          "body": "If you have questions or concerns about these terms, you can reach us by email at {email} or via in-app support. Our team is ready to respond."
        }
