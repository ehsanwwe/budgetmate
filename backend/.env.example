# LLM provider
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

APP_TIMEZONE=Asia/Tehran
AGENT_DEBUG_TRACE=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
OTP_MOCK_CODE=123456
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
DATABASE_URL=sqlite:///./budgetmate.db
CORS_ORIGINS=http://localhost:3000
STARTER_FREE_TOKENS=20000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_OAUTH_FRONTEND_SUCCESS_URL=http://localhost:3000/fa
GOOGLE_OAUTH_FRONTEND_ERROR_URL=http://localhost:3000/fa/login

# Production values (set these in backend/.env on the server):
# GOOGLE_REDIRECT_URI=https://apijibyar.digent24.com/api/auth/google/callback
